{
	"schemaVersion": 2,
	"id": "v2-random-cap",
	"name": "V2 — Random Hostile CAP",
	"description": "Phase 10a smoke-test scenario. 3–6 hostile-red fighters scattered across a 12 km disc 50 km north of the player, each rolled with a random AAM loadout (BVR-heavy or WVR-heavy), random heading, random speed. Demonstrates the new schema features end-to-end: count random spec, origin.random disc, headingDeg `{ any: true }`, speedMps band, loadout oneOf, plus a fixed Krasukha jammer at world-anchored coordinates and a SA-15 with a random magazine depth.",
	"autoSpawn": false,
	"randomSeed": 1337,

	"spawns": [
		{
			"type": "fighter",
			"team": { "weighted": [["hostile-red", 4], ["hostile-blue", 1]] },
			"count": { "min": 3, "max": 6 },
			"origin": {
				"random": {
					"centerRelTo": "player",
					"bearingDeg": 0,
					"rangeM": 50000,
					"radiusM": 12000,
					"altMode": "fromBand",
					"altMin": 6000,
					"altMax": 11000
				}
			},
			"headingDeg": { "any": true },
			"speedMps": { "from": 220, "to": 320 },
			"loadout": {
				"oneOf": [
					{ "AIM-120": 4, "AIM-9X": 2 },
					{ "METEOR": 4, "AIM-9X": 2 },
					{ "R-77": 4, "R-73": 2 },
					{ "R-37M": 2, "R-77": 2, "R-73": 2 }
				]
			}
		},
		{
			"type": "platform",
			"platformId": "krasukha-jammer",
			"team": "hostile-red",
			"origin": { "relTo": "player", "bearingDeg": 0, "rangeM": 55000, "altOffsetM": -3000 },
			"intel": { "level": "suspected", "uncertaintyM": 6000 }
		},
		{
			"type": "platform",
			"platformId": "sa-15-tor",
			"team": "hostile-red",
			"origin": { "relTo": "player", "bearingDeg": 5, "rangeM": 52000, "altOffsetM": -3000 },
			"magazine": { "missileRange": [2, 6] },
			"intel": { "level": "known" }
		}
	]
}
